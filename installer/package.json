{
  "name": "@enzo-ai/installer",
  "version": "0.1.0",
  "private": true,
  "description": "Enzo AI unified installer",
  "repository": {
    "type": "git",
    "url": "https://github.com/eranabir/enzo-ai.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "dist:win": "yarn build && electron-builder --win",
    "dist:mac": "yarn build && electron-builder --mac",
    "dist:linux": "yarn build && electron-builder --linux",
    "dist:win:publish": "yarn build && electron-builder --win --publish always",
    "dist:mac:publish": "yarn build && electron-builder --mac --publish always",
    "dist:linux:publish": "yarn build && electron-builder --linux --publish always"

  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.3"
  }
}
