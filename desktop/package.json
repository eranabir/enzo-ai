{
  "name": "@enzo-ai/desktop",
  "version": "4.0.0",
  "private": true,
  "description": "Enzo AI — self-hosted local AI assistant",
  "author": {
    "name": "Enzo AI",
    "email": "eranabir@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eranabir/enzo-ai.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "start": "yarn build && electron .",
    "dist": "yarn build && electron-builder --config electron-builder.config.js --publish never",
    "dist:win": "yarn build && electron-builder --config electron-builder.config.js --win --publish never",
    "dist:mac": "yarn build && electron-builder --config electron-builder.config.js --mac --publish never",
    "dist:linux": "yarn build && electron-builder --config electron-builder.config.js --linux --publish never",
    "package:win": "electron-builder --config electron-builder.config.js --win --publish never",
    "package:mac": "electron-builder --config electron-builder.config.js --mac --publish never",
    "package:mac:x64": "electron-builder --config electron-builder.config.js --mac --x64 --publish never",
    "package:mac:arm64": "electron-builder --config electron-builder.config.js --mac --arm64 --publish never",
    "package:linux": "electron-builder --config electron-builder.config.js --linux --publish never"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "better-sqlite3": "^11.8.1",
    "electron-squirrel-startup": "^1.0.0",
    "pdfjs-dist": "^6.1.200",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.3"
  }
}
