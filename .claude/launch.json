{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "shotokan-web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "-C",
        "C:\\projects\\manager-karate\\shotokan-v3",
        "--filter",
        "@shotokan/web",
        "dev"
      ],
      "port": 3000
    },
    {
      "name": "enzo-ai",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["dev"],
      "port": 5310
    },
    {
      "name": "web",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["dev:web"],
      "port": 5310
    },
    {
      "name": "landing",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "docs", "-p", "4000", "--no-clipboard"],
      "port": 4000
    },
    {
      "name": "site",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "site", "-p", "4100", "--no-clipboard"],
      "port": 4100
    }
  ]
